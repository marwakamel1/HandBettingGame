@inherits LayoutComponentBase

<div class="min-h-screen bg-gradient-to-b from-slate-950 via-slate-900 to-slate-950 text-slate-100">
    <header class="border-b border-slate-800/80 bg-slate-950/70 backdrop-blur">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-3">
            <a href="" class="text-lg font-semibold tracking-tight text-amber-100/95 hover:text-amber-50">
                Hand Betting
            </a>
            <nav class="flex gap-4 text-sm text-slate-300">
                <NavLink href="" Match="NavLinkMatch.All" class="hover:text-white" ActiveClass="text-amber-300 underline underline-offset-4">
                    Landing
                </NavLink>
                <NavLink href="game" class="hover:text-white" ActiveClass="text-amber-300 underline underline-offset-4">
                    Game
                </NavLink>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
        @Body
    </main>
</div>
